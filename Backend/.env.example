APP_NAME="JPMS Backend"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://backend.internal

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Backend has no Postgres/Mongo credentials at all — only Redis for its
# OWN session/token-cache concerns (jpms-backend:* keys).
DB_CONNECTION=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=redis
CACHE_PREFIX=jpms_backend

# Dedicated Redis server (own session/token cache only).
REDIS_CLIENT=phpredis
REDIS_HOST=redis.internal
REDIS_PASSWORD=
REDIS_PORT=6379

# Upstream: the one and only API this app is allowed to call.
API_URL=https://api.internal/api
API_SHARED_SECRET=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
