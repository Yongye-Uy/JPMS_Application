APP_NAME="JPMS API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.internal

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# API is a stateless gateway: no DB/Redis/Mongo credentials at all.
DB_CONNECTION=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# Upstream: the one and only backend this app is allowed to call
# (Central-Service's own dedicated server).
CENTRAL_SERVICE_URL=https://central-service.internal/api
CENTRAL_SERVICE_TOKEN=

# Downstream: the secret Backend must present to this app.
API_SHARED_SECRET=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
